{
  "name": "berichtspilot",
  "productName": "Berichtspilot",
  "version": "1.1.0",
  "description": "Ausbildungsnachweis-Generator für das digitale IHK-Berichtsheft",
  "author": "Rexi255",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/Rexi255/berichtspilot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rexi255/berichtspilot.git"
  },
  "bugs": {
    "url": "https://github.com/Rexi255/berichtspilot/issues"
  },
  "keywords": [
    "electron",
    "berichtsheft",
    "ausbildungsnachweis",
    "ihk",
    "azubi",
    "fachinformatiker",
    "react",
    "vite",
    "desktop-app",
    "installer",
    "portable"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:renderer": "vite build",
    "start": "npm run build:renderer && electron .",
    "build": "npm run build:renderer && electron-builder --win --linux --publish never",
    "build:win": "npm run build:renderer && electron-builder --win --publish never",
    "build:linux": "npm run build:renderer && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "io.github.rexi255.berichtspilot",
    "productName": "Berichtspilot",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Berichtspilot",
      "uninstallDisplayName": "Berichtspilot ${version}",
      "deleteAppDataOnUninstall": false,
      "artifactName": "Berichtspilot-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Berichtspilot-${version}-portable.exe"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "artifactName": "Berichtspilot-${version}.AppImage"
    }
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  }
}
